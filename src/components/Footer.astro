---
import { contact } from '../data/contact';
import { tagline } from '../data/site';
---

<footer class="border-t border-[var(--color-paper-dark)] bg-[var(--color-paper-dark)] py-10 mt-auto">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      <div>
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wide text-[var(--color-ink-muted)] mb-2">
          Address
        </h2>
        <p class="text-[var(--color-ink)]">
          {contact.address.line}
        </p>
      </div>
      <div>
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wide text-[var(--color-ink-muted)] mb-2">
          Connect
        </h2>
        <p class="text-[var(--color-ink)]">
          <a
            href={contact.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-accent)] hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 rounded"
          >
            Facebook
          </a>
        </p>
        <a href={`mailto:${contact.email}`} class="mt-1 block text-[var(--color-accent)] hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 rounded">
          {contact.email}
        </a>
        <a
          href="/visit"
          class="mt-1 inline-block text-[var(--color-accent)] hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 rounded"
        >
          Hours &amp; contact
        </a>
      </div>
      <div class="sm:col-span-2 md:col-span-1">
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wide text-[var(--color-ink-muted)] mb-2">
          Hours
        </h2>
        <p class="text-[var(--color-ink)] text-sm">
          {contact.hoursNote}
        </p>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-[var(--color-paper)]">
      <p class="text-sm italic text-[var(--color-ink-muted)] mb-2">{tagline}</p>
      <p class="text-sm text-[var(--color-ink-muted)]">
        © {new Date().getFullYear()} {contact.name}. All rights reserved.
      </p>
      <p class="mt-2 text-xs text-[var(--color-ink-muted)]">
        Premises monitored by video surveillance.
      </p>
    </div>
  </div>
</footer>
