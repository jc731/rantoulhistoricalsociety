---
import { contact } from '../data/contact';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Visit', href: '/visit' },
  { label: 'Exhibits', href: '/exhibits' },
  { label: 'Events', href: '/events' },
  { label: 'Support', href: '/support' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-paper-dark)] bg-[var(--color-paper)]/95 backdrop-blur">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 flex flex-wrap items-center justify-between gap-4 py-4">
    <a href="/" class="font-heading text-xl font-semibold text-[var(--color-ink)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 rounded">
      {contact.name}
    </a>
    <nav aria-label="Main navigation" class="flex flex-wrap items-center gap-1 sm:gap-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2 rounded text-[var(--color-ink-muted)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent-light)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/support"
        class="ml-2 px-3 py-2 rounded bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
      >
        Support
      </a>
    </nav>
  </div>
</header>
