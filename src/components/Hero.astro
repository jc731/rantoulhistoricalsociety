---
interface Props {
  headline: string;
  intro?: string;
  /** Banner image from registry (file_name). Rendered from /images/{file_name}. */
  bannerFileName?: string;
  /** Alt text for banner (from image-assets.json). */
  bannerAlt?: string;
  /** Primary CTA: { label, href } */
  primaryCta?: { label: string; href: string };
  /** Secondary CTA */
  secondaryCta?: { label: string; href: string };
  /** Optional soft CTA (e.g. Support) */
  supportCta?: { label: string; href: string };
}

const { headline, intro, bannerFileName, bannerAlt, primaryCta, secondaryCta, supportCta } = Astro.props;
---

<header class="relative bg-[var(--color-paper-dark)] py-16 md:py-24 px-4 text-center overflow-hidden">
  {bannerFileName && bannerAlt && (
    <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
      <img
        src={`/images/${bannerFileName}`}
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-20 object-center"
        width="1600"
        height="800"
        fetchpriority="high"
      />
    </div>
  )}
  <div class="relative z-10 mx-auto max-w-3xl">
    <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-ink)] mb-4">
      {headline}
    </h1>
    {intro && <p class="text-lg md:text-xl text-[var(--color-ink-muted)] mb-8 max-w-2xl mx-auto">{intro}</p>}
    <div class="flex flex-wrap gap-4 justify-center items-center">
      {primaryCta && (
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center rounded-md px-6 py-3 font-medium bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
        >
          {primaryCta.label}
        </a>
      )}
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center rounded-md px-6 py-3 font-medium border-2 border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent-light)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
        >
          {secondaryCta.label}
        </a>
      )}
      {supportCta && (
        <a
          href={supportCta.href}
          class="inline-flex items-center justify-center rounded-md px-6 py-3 font-medium text-[var(--color-ink-muted)] hover:text-[var(--color-accent)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
        >
          {supportCta.label}
        </a>
      )}
    </div>
  </div>
</header>
