---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  description?: string;
  width?: number;
  height?: number;
  class?: string;
  /** Show description as caption */
  showCaption?: boolean;
}

const { src, alt, description, width, height, class: className = '', showCaption = false } = Astro.props;
---

<figure class={className}>
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    class="rounded-lg w-full h-auto"
    loading="lazy"
    decoding="async"
  />
  {showCaption && description && (
    <figcaption class="mt-2 text-sm text-[var(--color-ink-muted)]">{description}</figcaption>
  )}
</figure>
