---
interface Props {
  title?: string;
  id?: string;
  /** Narrow content width for readability */
  narrow?: boolean;
  class?: string;
}

const { title, id, narrow = false, class: className = '' } = Astro.props;
---

<section id={id} class={`py-8 md:py-12 ${className}`} aria-labelledby={title ? `${id || 'section'}-heading` : undefined}>
  <div class:list={['mx-auto px-4 sm:px-6', narrow ? 'max-w-2xl' : 'max-w-4xl']}>
    {title && (
      <h2 id={`${id || 'section'}-heading`} class="font-heading text-2xl md:text-3xl font-semibold text-[var(--color-ink)] pb-3 mb-5 border-b border-[var(--color-accent-2)]">
        {title}
      </h2>
    )}
    <slot />
  </div>
</section>
