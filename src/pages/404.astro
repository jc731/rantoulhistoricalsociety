---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Rantoul Historical Society"
  description="The page you're looking for may have moved or no longer exists."
>
  <header class="bg-[var(--color-paper-dark)] py-12 md:py-16 px-4 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-[var(--color-ink)]">We couldn't find that page</h1>
      <p class="mt-4 text-lg text-[var(--color-ink-muted)]">
        The page you're looking for may have moved or no longer exists.
      </p>
    </div>
  </header>

  <section class="py-12 md:py-16 px-4">
    <div class="mx-auto max-w-xl text-center">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md px-6 py-3 font-medium bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
        >
          Return to home
        </a>
        <a
          href="/visit"
          class="inline-flex items-center justify-center rounded-md px-6 py-3 font-medium border-2 border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent-light)] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2"
        >
          Plan a visit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
