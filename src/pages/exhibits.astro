---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { exhibits } from '../data/exhibits';
import { getImageAssets, getPublicImageUrl } from '../data/image-assets';

const galleryImages = getImageAssets().filter(
  (img) => img.category !== 'Facilities'
);
---

<BaseLayout
  title="Exhibits"
  description="Explore exhibits at the Rantoul Historical Society Museum: railroad history, Chanute Air Force Base, everyday life, and more."
>
  <header class="bg-[var(--color-paper-dark)] py-12 md:py-16 px-4 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-[var(--color-ink)]">Exhibits</h1>
      <p class="mt-4 text-lg text-[var(--color-ink-muted)]">
        Our museum highlights the people, places, and events that shaped Rantoul — from early settlement to Chanute AFB and beyond.
      </p>
    </div>
  </header>

  <Section title="Current Exhibits" id="current">
    <p class="text-[var(--color-ink-muted)] mb-8">
      Exhibits evolve as new materials are collected. Below are key themes you can explore. <!-- TODO: Add specific exhibit names when provided by stakeholder. -->
    </p>
    <div class="grid gap-6 sm:grid-cols-2">
      {exhibits.map((exhibit) => (
        <Card title={exhibit.title}>
          <p>{exhibit.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section title="Museum Gallery" id="gallery">
    <p class="text-[var(--color-ink-muted)] mb-8">
      A selection of photographs from our museum collection.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {galleryImages.map((img) => (
        <figure>
          <img
            src={getPublicImageUrl(img.file_name)}
            alt={img.alt_text}
            width="600"
            height="450"
            class="rounded-lg w-full h-48 object-cover"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="mt-2 text-xs text-[var(--color-ink-muted)]">{img.description}</figcaption>
        </figure>
      ))}
    </div>
  </Section>
</BaseLayout>
