---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { exhibits } from '../data/exhibits';
import { getImageAssets, getPublicImageUrl } from '../data/image-assets';

const galleryImages = getImageAssets().filter(
  (img) => img.category !== 'Facilities'
);

function parseDims(dimensions: string): { w: number; h: number } {
  const match = dimensions.match(/^(\d+)x(\d+)$/);
  if (match) return { w: parseInt(match[1]), h: parseInt(match[2]) };
  return { w: 1200, h: 900 };
}
---

<BaseLayout
  title="Exhibits"
  description="Explore exhibits at the Rantoul Historical Society Museum: railroad history, Chanute Air Force Base, everyday life, and more."
>
  <header class="bg-[var(--color-paper-dark)] py-12 md:py-16 px-4 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-[var(--color-ink)]">Exhibits</h1>
      <p class="mt-4 text-lg text-[var(--color-ink-muted)]">
        Our museum highlights the people, places, and events that shaped Rantoul — from early settlement to Chanute AFB and beyond.
      </p>
    </div>
  </header>

  <Section title="Current Exhibits" id="current">
    <p class="text-[var(--color-ink-muted)] mb-8">
      Exhibits evolve as new materials are collected. Below are key themes you can explore. <!-- TODO: Add specific exhibit names when provided by stakeholder. -->
    </p>
    <div class="grid gap-6 sm:grid-cols-2">
      {exhibits.map((exhibit) => (
        <Card title={exhibit.title}>
          <p>{exhibit.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section title="Museum Gallery" id="gallery">
    <p class="text-[var(--color-ink-muted)] mb-8">
      A selection of photographs from our museum collection. Click any image to view full size.
    </p>
    <div id="pswp-gallery" class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {galleryImages.map((img) => {
        const dims = parseDims(img.dimensions);
        return (
          <figure>
            <a
              href={getPublicImageUrl(img.file_name)}
              data-pswp-width={dims.w}
              data-pswp-height={dims.h}
              data-caption={img.description}
              class="block cursor-zoom-in rounded-lg overflow-hidden"
            >
              <img
                src={getPublicImageUrl(img.file_name)}
                alt={img.alt_text}
                width="600"
                height="450"
                class="w-full h-48 object-cover transition-transform duration-200 hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </a>
            <figcaption class="mt-2">
              <span class="text-[10px] font-semibold uppercase tracking-wide text-[var(--color-accent-2)]">{img.category}</span>
              <p class="text-xs text-[var(--color-ink-muted)] mt-0.5">{img.description}</p>
            </figcaption>
          </figure>
        );
      })}
    </div>
  </Section>
</BaseLayout>

<style is:global>
  @import 'photoswipe/style.css';

  .pswp__custom-caption {
    background: rgba(0, 0, 0, 0.65);
    font-size: 0.8125rem;
    line-height: 1.4;
    color: #fff;
    max-width: 480px;
    padding: 6px 14px;
    border-radius: 4px;
    position: absolute;
    left: 50%;
    bottom: 20px;
    transform: translateX(-50%);
    text-align: center;
    pointer-events: none;
  }

  .pswp__custom-caption:empty {
    display: none;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#pswp-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    preload: [1, 2],
  });

  lightbox.on('uiRegister', function () {
    lightbox.pswp.ui.registerElement({
      name: 'custom-caption',
      order: 9,
      isButton: false,
      appendTo: 'root',
      onInit: (el, pswp) => {
        pswp.on('change', () => {
          const slide = pswp.currSlide?.data?.element;
          el.textContent = slide?.dataset?.caption ?? '';
        });
      },
    });
  });

  lightbox.init();
</script>
