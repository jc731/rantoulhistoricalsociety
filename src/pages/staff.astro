---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { staff } from '../data/staff';
---

<BaseLayout
  title="Staff & Volunteers"
  description="Meet the dedicated staff and volunteers who keep the Rantoul Historical Society & Museum running."
>
  <header class="bg-[var(--color-paper-dark)] py-12 md:py-16 px-4 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-[var(--color-ink)]">Staff & Volunteers</h1>
      <p class="mt-4 text-lg text-[var(--color-ink-muted)]">
        The Rantoul Historical Society is run by dedicated community members who give their time to preserve local history.
      </p>
    </div>
  </header>

  <Section id="staff-list" narrow>
    {staff.length > 0 ? (
      <div class="space-y-8">
        {staff.map((member) => (
          <div class="flex flex-col sm:flex-row gap-5 rounded-lg border border-[var(--color-paper-dark)] bg-white p-5">
            {member.photo ? (
              <div class="shrink-0">
                <img
                  src={`/images/${member.photo}`}
                  alt={`Photo of ${member.name}`}
                  width="96"
                  height="96"
                  class="rounded-full w-24 h-24 object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ) : (
              <div class="shrink-0 w-24 h-24 rounded-full bg-[var(--color-paper-dark)] flex items-center justify-center" aria-hidden="true">
                <span class="text-3xl text-[var(--color-ink-muted)]">?</span>
              </div>
            )}
            <div>
              <h2 class="font-heading text-lg font-semibold text-[var(--color-ink)]">{member.name}</h2>
              <p class="text-sm text-[var(--color-accent)] font-medium mb-2">{member.role}</p>
              <p class="text-sm text-[var(--color-ink-muted)]">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="rounded-lg border border-[var(--color-paper-dark)] bg-white p-8 text-center">
        <p class="text-[var(--color-ink)] font-medium mb-2">Staff profiles coming soon.</p>
        <p class="text-sm text-[var(--color-ink-muted)]">
          We're a volunteer-run organization. Check back shortly to meet the people who keep the museum going.
        </p>
      </div>
    )}

    <div class="mt-10 rounded-lg bg-[var(--color-paper-dark)] p-5">
      <p class="text-[var(--color-ink-muted)]">
        Interested in joining the team? <a href="/volunteer" class="text-[var(--color-accent)] hover:underline font-medium">Apply to volunteer →</a>
      </p>
    </div>
  </Section>
</BaseLayout>
