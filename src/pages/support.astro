---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { contact } from '../data/contact';
import {
  membershipLevels,
  membershipCheckPayable,
  membershipMailInstructions,
} from '../data/membership';
---

<BaseLayout
  title="Support"
  description="Support the Rantoul Historical Society through membership, volunteering, artifact donations, or financial contributions. Online donations planned for the future."
>
  <header class="bg-[var(--color-paper-dark)] py-12 md:py-16 px-4 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-[var(--color-ink)]">Supporting the Rantoul Historical Society</h1>
      <p class="mt-4 text-lg text-[var(--color-ink-muted)]">
        The Society relies on the support of members, volunteers, and the community to continue preserving Rantoul's history.
      </p>
    </div>
  </header>

  <Section title="Ways to Support" id="ways">
    <ul class="list-disc pl-6 space-y-2 text-[var(--color-ink-muted)]">
      <li>Becoming a member</li>
      <li>Volunteering your time</li>
      <li>Donating artifacts or historical materials</li>
      <li>Making financial contributions (online donations planned for the future)</li>
    </ul>
  </Section>

  <Section title="Be a part of preserving Rantoul's history!" id="membership">
    <p class="text-[var(--color-ink-muted)] mb-8 max-w-2xl">
      Membership directly supports the museum's day-to-day work: caring for artifacts, sharing stories with visitors, and keeping local history accessible. When you join, you're helping ensure that the people, places, and moments that shaped Rantoul stay part of the community's story.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 mb-10">
      {membershipLevels.map((level) => (
        <Card title={level.name}>
          <p class="text-[var(--color-ink)] font-semibold mb-2">
            ${level.price}/{level.period === 'year' ? 'year' : 'one-time'}
          </p>
          <p class="text-[var(--color-ink-muted)]">{level.blurb}</p>
        </Card>
      ))}
    </div>
    <div class="rounded-lg border border-[var(--color-paper-dark)] bg-[var(--color-paper-dark)] p-6 max-w-2xl">
      <h3 class="font-heading text-lg font-semibold text-[var(--color-ink)] mb-3">How to join</h3>
      <p class="text-[var(--color-ink-muted)] mb-2">
        Make checks payable to: <strong class="text-[var(--color-ink)]">{membershipCheckPayable}</strong>
      </p>
      <p class="text-[var(--color-ink-muted)] mb-2">
        {membershipMailInstructions}
      </p>
      <p class="text-[var(--color-ink)] font-medium">
        {contact.address.line}
      </p>
      <p class="mt-4 text-sm text-[var(--color-ink-muted)]">
        Include your name, address, and phone number with your payment. Questions? <a href="/contact" class="text-[var(--color-accent)] hover:underline">Contact us</a> or stop by during <a href="/visit" class="text-[var(--color-accent)] hover:underline">museum hours</a>.
      </p>
    </div>
  </Section>

  <Section title="Volunteering" id="volunteering">
    <p class="text-[var(--color-ink-muted)] mb-4">
      The best way to get involved is to <a href="/visit" class="text-[var(--color-accent)] hover:underline">visit the museum</a>. If you're interested in volunteering your time, we'd love to hear from you.
    </p>
    <p class="text-[var(--color-ink-muted)]">
      For volunteer opportunities, please <a href="/contact" class="text-[var(--color-accent)] hover:underline">contact us</a> or stop by during museum hours.
    </p>
  </Section>

  <Section title="Donations" id="donations">
    <p class="text-[var(--color-ink-muted)] mb-4">
      Financial contributions help preserve local history and keep the museum accessible. <strong class="text-[var(--color-ink)]">Online donations are not yet available.</strong> We are planning to offer online giving in the future.
    </p>
    <p class="text-[var(--color-ink-muted)] mb-4">
      <strong class="text-[var(--color-ink)]">In-person donations:</strong> Free-will donations are accepted when you visit the museum. Your support is greatly appreciated.
    </p>
    <p class="text-sm text-[var(--color-ink-muted)]">
      <strong class="text-[var(--color-ink)]">Planned future options</strong> (not yet active): PayPal Donate, Stripe donation form, Donorbox, or Square payment links. We will announce when online giving is available.
    </p>
  </Section>
</BaseLayout>
